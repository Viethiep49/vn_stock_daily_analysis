# ========= LLM — Điền ít nhất 1 key (Gemini miễn phí, khuyên dùng) =========
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Lấy tại: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama local (không cần key, cần cài ollama)
OLLAMA_API_BASE=http://localhost:11434

# ========= Cấu hình LLM Router =============================================
# Model ưu tiên (format: provider/model-name)
LLM_PRIMARY_MODEL=gemini/gemini-2.0-flash
# Model dự phòng khi model chính lỗi
LLM_BACKUP_MODEL=gemini/gemini-1.5-flash

# ========= Telegram Bot (tuỳ chọn) =========================================
# 1. Nhắn /newbot tới @BotFather trên Telegram để tạo bot
# 2. Copy token vào đây
TELEGRAM_BOT_TOKEN=
# 3. Lấy chat_id: nhắn bất kỳ vào bot, truy cập
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ========= Discord Webhook (tuỳ chọn) ========================================
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# ========= vnstock (tuỳ chọn, KBS source hoạt động miễn phí) ================
VNSTOCK_API_KEY=

# ========= Cài đặt khác =====================================================
REPORT_LANGUAGE=vi
